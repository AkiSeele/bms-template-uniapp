# 依赖目录
node_modules/

# 编译与打包产物
dist/
unpackage/
bin/

# HBuilderX 局部配置及缓存
.hbuilderx/

# VS Code 局部配置及缓存（排除共享配置如 extensions.json/settings.json，可按需精细管理）
.vscode/

# WebStorm / IDEA 局部配置及缓存
.idea/

# Android 签名证书目录与证书文件（敏感证书与私钥，绝对禁止提交版本库）
keystore/
*.keystore
*.jks

# 临时编译与诊断输出文件
tsc_output.txt
tsc_output_utf8.txt
*.tsbuildinfo

# Codegraph 本地数据库及索引缓存
.codegraph/

# 操作系统临时文件
.DS_Store
Thumbs.db
desktop.ini

# 包管理器日志与报错日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地环境变量配置文件（通常包含敏感 API 密钥或私有配置）
.env.local
.env.*.local
*.local
